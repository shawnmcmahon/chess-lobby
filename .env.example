# Convex (from `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Web app — copy CONVEX_URL with VITE_ prefix
# VITE_CONVEX_URL=

# Google OAuth (Convex dashboard / `npx convex env set`)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Chess engine (Convex + apps/chess-engine)
# ENGINE_API_URL=http://localhost:8080
# ENGINE_API_KEY=change-me
