# Convex (from `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Web app — copy CONVEX_URL with VITE_ prefix
# VITE_CONVEX_URL=

# Google OAuth (Convex dashboard / `npx convex env set`)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Chess engine — optional public .NET Stockfish service (cloud Convex ignores localhost)
# Default: built-in minimax engine in Convex. Set a public URL to use Stockfish instead.
# ENGINE_API_URL=https://your-engine.example.com
# ENGINE_API_KEY=change-me
