# Convex (from `npx convex dev`)
CONVEX_DEPLOYMENT=
CONVEX_URL=
CONVEX_SITE_URL=

# Web app — copy CONVEX_URL with VITE_ prefix
# VITE_CONVEX_URL=

# Google OAuth (Convex dashboard / `npx convex env set`)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Email verification for password sign-up (Resend — `npx convex env set`)
# AUTH_RESEND_KEY=
# AUTH_RESEND_FROM=Chess Lobby <onboarding@resend.dev>

# Chess engine — optional public .NET Stockfish service (cloud Convex ignores localhost)
# Default: built-in minimax engine in Convex. Set a public URL to use Stockfish instead.
# ENGINE_API_URL=https://your-engine.example.com
# ENGINE_API_KEY=change-me

# --- AWS backend rewrite (feature/aws-backend-rewrite branch) ---
# VITE_WS_URL=wss://your-api.execute-api.us-east-1.amazonaws.com/dev
# VITE_API_URL=https://your-api.execute-api.us-east-1.amazonaws.com/dev
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
